	<!-- End Google Tag Manager -->
	<title>LabourPest | Profesyonel Haşere Kontrol ve İlaçlama Hizmeti</title>
	<meta name="description" content="LabourPest olarak ev ve iş yerleriniz için böcek, fare, tahta kurusu ve tüm haşere türlerine karşı garantili ilaçlama hizmeti sunuyoruz.">
	<meta name="keywords" content="ilaçlama, pest control, böcek ilaçlama, haşere kontrolü, Konya ilaçlama, profesyonel ilaçlama">
	<meta charset="utf-8">
	<!--[if IE]>
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<![endif]-->
	<meta name="description" content="">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

	<!-- Open Graph -->
	<meta property="og:title" content="LabourPest - Antalya, İzmir ve Muğla İlaçlama Firması" />
	<meta property="og:description" content="Antalya, İzmir ve Muğla bölgelerinde profesyonel haşere kontrol hizmeti." />
	<meta property="og:image" content="https://labourpest.com/labourpestcustomer/assets/img/logo.png" />
	<meta property="og:url" content="https://labourpest.com" />
	<meta property="og:type" content="website" />

	<!-- Schema.org JSON-LD -->
	<script type="application/ld+json">
		{
		  "@@context": "https://schema.org",
		  "@@type": "LocalBusiness",
		  "name": "LabourPest",
		  "image": "https://labourpest.com/labourpestcustomer/assets/img/logo.png",
		  "@@id": "https://labourpest.com",
		  "url": "https://labourpest.com",
		  "telephone": "+90-533-699-2275",
		  "address": {
			"@@type": "PostalAddress",
			"streetAddress": "Merkez",
			"addressLocality": "Antalya, İzmir, Muğla",
			"postalCode": "00000",
			"addressCountry": "TR"
		  },
		  "geo": {
			"@@type": "GeoCoordinates",
			"latitude": 36.8969,
			"longitude": 30.7133
		  },
		  "openingHours": "Mo-Sa 09:00-18:00",
		  "sameAs": [
			"https://facebook.com/labourpest",
			"https://instagram.com/labourpest",
			"https://linkedin.com/company/labourpest"
		  ]
		}
	</script>

	<link rel="canonical" href="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path" />


	<!-- Place favicon.ico and apple-touch-icon.png in the root directory -->


  @await Component.InvokeAsync("CssComponentViewPartial")


</head>

<body>
	<!-- Google Tag Manager (noscript) -->
	<noscript>
		<iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5QFHVNCT"
				height="0" width="0" style="display:none;visibility:hidden"></iframe>
	</noscript>
	<!-- End Google Tag Manager (noscript) -->

	<div class="preloader">
		<div class="preloader_image"></div>
	</div>

	<!-- search modal -->


	<div id="login-form" class="ls modal c-gutter-0">
		<button type="button" class="close" data-dismiss="modal" aria-label="Close">
			<span aria-hidden="true">&times;</span>
		</button>
		<div class="container">
			<div class="row">
				<div class="col-md-6 ds column-overlay">
					<img src="~/canabicom/images/signup1.webp" alt="" loading="lazy" width="410" height="598">
				</div>
				<div class="col-md-6 ls">
					<div class="divider-65 hidden-below-md"></div>
					<div class="divider-60 hidden-above-md"></div>
					<h4 class="special-heading text-center text-capitalize">Admin Giriş Paneli</h4>

					<form class="contact-form c-mb-30 c-gutter-20" method="post" asp-action="SignIN" asp-controller="Login">

						<div class="row">
							<div class="col-sm-12">
								<div class="form-group has-placeholder">
									<label for="name">Kullanıcı Adı <span class="required">*</span></label>

									<input type="text" aria-required="true" size="30" value="" name="WriterMail" id="name" class="form-control" placeholder="Kullanıcı Adı">
								</div>
							</div>
							<div class="col-sm-12">
								<div class="form-group has-placeholder">
									<label for="password">Password<span class="required">*</span></label>

									<input type="password" aria-required="true" size="30" value="" name="WriterPassword" id="password" class="form-control" placeholder="Şifre">
								</div>
							</div>
							<div class="col-sm-12">
								<div class="form-group">

									<input type="checkbox" id="agree" name="agree" checked>
									<label for="agree">Site Kullanım Şartlarını Okudum Kabul Ediyorum..</label>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-sm-12">
								<div class="form-group">
									<a href="#" class="btn btn-with-border sign-in">Şifreni Mi Unuttun ?</a>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-sm-12 text-center">
								<div class="form-group">
									<input class="btn btn-maincolor" type="submit" value="Giriş Yap">
								</div>
							</div>
						</div>
					</form>

				</div>
			</div>
		</div>
	</div> <!--Burası Login Kısmı-->
	<div id="login-form3" class="ls modal c-gutter-0">
		<button type="button" class="close" data-dismiss="modal" aria-label="Close">
			<span aria-hidden="true">&times;</span>
		</button>
		<div class="container">
			<div class="row">
				<div class="col-md-6 ds column-overlay">
					<img src="~/canabicom/images/signup1.webp" alt="">
				</div>
				<div class="col-md-6 ls">
					<div class="divider-65 hidden-below-md"></div>
					<div class="divider-60 hidden-above-md"></div>
					<h4 class="special-heading text-center text-capitalize">Müşteri Giriş Paneli</h4>

					<form class="contact-form c-mb-30 c-gutter-20" method="post" asp-action="SignIN" asp-controller="Login">

						<div class="row">
							<div class="col-sm-12">
								<div class="form-group has-placeholder">
									<label for="name">Kullanıcı Adı <span class="required">*</span></label>

									<input type="text" aria-required="true" size="30" value="" name="name" id="name" class="form-control" placeholder="Kullanıcı Adı">
								</div>
							</div>
							<div class="col-sm-12">
								<div class="form-group has-placeholder">
									<label for="password">Password<span class="required">*</span></label>

									<input type="password" aria-required="true" size="30" value="" name="password" id="password" class="form-control" placeholder="Şifre">
								</div>
							</div>
							<div class="col-sm-12">
								<div class="form-group">

									<input type="checkbox" id="agree" name="agree" checked>
									<label for="agree">Site Kullanım Şartlarını Okudum Kabul Ediyorum..</label>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-sm-12">
								<div class="form-group">
									<a href="#" class="btn btn-with-border sign-in">Şifreni Mi Unuttun ?</a>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-sm-12 text-center">
								<div class="form-group">
									<input class="btn btn-maincolor" type="submit" value="Giriş Yap">
								</div>
							</div>
						</div>
					</form>

				</div>
			</div>
		</div>
	</div> <!--Burası Müşteri Giriş Kısmı-->

	<div id="login-form2" class="ls modal c-gutter-0">
		<div class="container">
			<div class="row">
				<div class="col-md-6 ds column-overlay">
					<img src="~/canabicom/images/signup1.webp" alt="">
				</div>
				<div class="col-md-6 align-items-center d-flex flex-column justify-content-center ls">
					<div class="divider-65 hidden-below-md"></div>
					<div class="divider-60 hidden-above-md"></div>
					<h4 class="special-heading text-center text-capitalize">Mail Adresiniz</h4>

					<form class="contact-form c-mb-30 c-gutter-20" method="post" asp-action="SignIN" asp-controller="Login">

						<div class="row">
							<div class="col-sm-12">
								<div class="form-group has-placeholder">
									<label for="name2">Mail Adresiniz<span class="required">*</span></label>

									<input type="text" aria-required="true" size="30" value="" name="name" id="name2" class="form-control" placeholder="Mail Adresiniz">
								</div>
							</div>

							

						</div>
					@* 	<div class="row">
							<div class="col-sm-12">
								<a href="#" class="btn btn-with-border">Giriş Yap</a>
							</div>
						</div> *@
						<div class="row">
							<div class="col-sm-12 text-center">
								<div class="form-group">
									<input class="btn btn-maincolor" type="submit" value="Şifreyi Sıfırla">
								</div>
							</div>
						</div>
					</form>

				</div>
			</div>
		</div>
	</div> <!--Burası Register Kısmı-->
	@{
		bool showComponents = ViewData["ShowComponents"] == null || (bool)ViewData["ShowComponents"];
	}

	

	<div id="canvas">
		<div id="box_wrapper">
			@RenderBody()
			<!-- template sections -->
			 @if (showComponents)
        {
			<!--topline section visible only on small screens|-->
			@await Component.InvokeAsync("PageTopLineViewComponentPartial") <!--sayfanın üst kısmı sosyal medya alanlarının bulunduğu kısım-->
			

			<!-- header with two Bootstrap columns - left for logo and right for navigation -->
			@await Component.InvokeAsync("PageHeaderViewComponentPartial") <!-- Header Component Burası Sayfanın Üst Menülerinin ve Logonun bulunduğu kısım sağ kısımda Giriş yap butonu var-->

			

			@await Component.InvokeAsync("PageSliderViewComponentPartial") <!--Burası En Başta Bulunan Slider Kısmı Kalite Hizmet ile başlayan kısım-->
				@* @await Component.InvokeAsync("ProductAlternatifViewComponentPartial") <!--Burası Popüler Ürünlerin Başladığı Kısım--> *@
                @await Component.InvokeAsync("AboutUsViewComponentPartial") <!--Burası Hakkımızda Kısmı-->

			@await Component.InvokeAsync("ServicesViewComponentPartial") <!--Burası Servislerin Bulunduğu Kısım Ürünlerin Hemen Altında Bulunan Kısım-->

			@await Component.InvokeAsync("BrandsViewComponentPartial") @* MARKALAR *@ <!--Burası Markaların Bulunduğu Kısım-->

			@await Component.InvokeAsync("WhoWeUsViewComponentPartial") <!-- Vizyonumuz Misyonumuz'un bulunduğu Kısımlar-->

			@await Component.InvokeAsync("PhotosViewComponentPartial") <!--Resimlerin Bulunduğu Alan Fotoğraf Galerisi-->

			@await Component.InvokeAsync("CategoriesViewComponentPartial") <!--Kategorilerin Bulunduğu Alan-->

			@await Component.InvokeAsync("SubscribeViewComponentPartial")  <!--Bültenimize Abone Olun Kısmı..-->

			@await Component.InvokeAsync("BlogsViewComponentPartial") <!--Blogların Bulunduğu Kısım-->

			@await Component.InvokeAsync("FAQViewComponentPartial") <!--Yorumların ve Sıkça Sorulan Soruların bulunduğu alan-->

			@await Component.InvokeAsync("TestimonialsViewComponentPartial") <!--Yorumların Bulunduğu Kısım Sıkça Sorulanların hemen alt kısmı-->
			@await Component.InvokeAsync("DeliveryViewComponentPartial") <!--Teslimat Bilgilerinin Bulunduğu Kısım-->
			@await Component.InvokeAsync("LocationMapViewComponentPartial") <!--Haritanın ve konumun bulunduğu alan-->

			@await Component.InvokeAsync("FooterViewComponentPartial") <!--Footer Alanın Bulunduğu Kısım Aşağıda bulunan iletişim abone olma kısımlarının bulunduğu kısımlar-->

			@await Component.InvokeAsync("BorderTopViewComponentPartial") <!--Telif Haklarının Bulunduğu Kısım Tüm Hakları Saklıdır..-->
			
		}
		</div><!-- eof #box_wrapper -->
	</div><!-- eof #canvas -->




	<script src="~/canabicom/js/compressed.js" defer></script>
	<script src="~/canabicom/js/main.js" defer></script>


</body>


</html>
