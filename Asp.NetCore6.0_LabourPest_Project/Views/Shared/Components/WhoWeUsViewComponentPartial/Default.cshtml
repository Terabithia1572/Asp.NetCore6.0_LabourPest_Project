@model List<WhoWeUs>

@foreach (var item in Model)
{
    var isRight = item.WhoWeUsClass == "s-cover-right";

    <section class="ls ms who-we-us-section s-pt-xl-140 s-pt-lg-120 s-pt-md-80 s-pt-50 s-pb-xl-145 s-pb-lg-125 s-pb-md-85 s-pb-55 text-center text-sm-left">
        <div class="cover-image @(isRight ? "s-cover-right" : "s-cover-left")">
            <img src="@item.WhoWeUsImageURL"
                 alt="@item.WhoWeUsTitle1 @item.WhoWeUsTitle2"
                 width="444"
                 height="555"
                 loading="lazy"
                 class="img-fluid who-image">
        </div>
        <div class="container-fluid">
            <div class="row">
                @if (isRight)
                {
                    <div class="col-lg-6">
                        <div class="content-center">
                            <h2 class="special-heading sub-title"><span>@item.WhoWeUsTitle1</span></h2>
                            <h2 class="special-heading">@item.WhoWeUsTitle2</h2>
                            <div class="divider-45 hidden-below-md"></div>
                            <div class="divider-30 hidden-above-md"></div>
                            <p>@item.WhoWeUsDescription1</p>
                            <p>@item.WhoWeUsDescription2</p>
                            <div class="divider-50 hidden-below-md"></div>
                            <div class="divider-30 hidden-above-md"></div>
                            <a class="btn btn-maincolor medium-btn" href="#">Daha Fazla..</a>
                        </div>
                    </div>
                    <div class="col-lg-6"></div>
                }
                else
                {
                    <div class="col-lg-6"></div>
                    <div class="col-lg-6">
                        <div class="content-center">
                            <h1 class="special-heading sub-title"><span>@item.WhoWeUsTitle1</span></h1>
                            <h2 class="special-heading">@item.WhoWeUsTitle2</h2>
                            <div class="divider-45 hidden-below-md"></div>
                            <div class="divider-30 hidden-above-md"></div>
                            <p>@item.WhoWeUsDescription1</p>
                            <p>@item.WhoWeUsDescription2</p>
                            <div class="divider-50 hidden-below-md"></div>
                            <div class="divider-30 hidden-above-md"></div>
                            <a class="btn btn-maincolor medium-btn" href="#">Daha Fazla..</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<style>
    .who-we-us-section .who-image {
        max-width: 100%;
        height: auto;
        object-fit: cover;
    }

    @@media (max-width: 768px) {
        .who-we-us-section .cover-image

    {
        text-align: center;
        margin-bottom: 20px;
    }

    .who-we-us-section .cover-image img {
        width: 100% !important;
        height: auto !important;
    }

    .who-we-us-section .content-center {
        text-align: center !important;
    }

    .who-we-us-section h1,
    .who-we-us-section h2,
    .who-we-us-section p {
        text-align: center !important;
    }

    }
</style>
