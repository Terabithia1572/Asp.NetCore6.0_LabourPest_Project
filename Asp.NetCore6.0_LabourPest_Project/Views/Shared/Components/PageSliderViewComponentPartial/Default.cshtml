@model List<HomePage>
@{
    bool isFirst = true;
    var firstImage = Model.FirstOrDefault()?.HomePageImage ?? "";
}
<!-- Görsel ön yükleme -->
<link rel="preload" as="image" href="@firstImage" />

<section class="page_slider">
    <div class="mouse_down">
        <a href="#about">
            <img src="~/canabicom/images/mouse.webp" alt="mouse" loading="lazy" width="14" height="24">
        </a>
        <svg width="320" height="45" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
            <g>
                <title>Layer 1</title>
                <g stroke="null" transform="translate(0,41) scale(0.1,-0.1)" fill="#000000" id="svg_1">
                    <path stroke="null" d="m1473.1,340.2c-80.8,-30 -133.3,-70 -259.1,-199c-125.8,-129 -190.4,-171 -286.5,-185c-28.3,-5 271.7,-8 666.4,-8s695.6,3 668.7,7c-98.4,15 -159.7,54 -290.2,187c-132.3,135 -177.4,169 -260.1,198c-51.5,18 -189.9,18 -239.2,0z" id="svg_2" />
                </g>
            </g>
        </svg>
    </div>

    <div class="flexslider">
        <ul class="slides">
            @foreach (var item in Model)
            {
                <li class="ds cover-image s-overlay text-left">
                    <img src="@item.HomePageImage"
                         alt="@item.HomePageDescription1 @item.HomePageDescription2"
                         class="homepage-slider-img"
                         loading="@(isFirst ? "eager" : "lazy")"
                         width="1920"
                         height="500" />

                    @{
                        isFirst = false;
                    }

                    <div class="container">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="intro_layers_wrapper">
                                    <div class="intro_layers">
                                        <div class="intro_layer">
                                            <h2 class="text-capitalize intro_featured_word">
                                                <span class="color-main">@item.HomePageDescription1</span> @item.HomePageDescription2
                                            </h2>

                                            @{
                                                var subDesc = item.HomePageSubDescription;
                                                if (subDesc.Contains("İŞİMİZ") && subDesc.Contains("GÜCÜMÜZ"))
                                                {
                                                    subDesc = subDesc
                                                    .Replace("İŞİMİZ", "<span style='color:#55c2bb; font-weight:bold;'>İŞİMİZ</span>")
                                                    .Replace("GÜCÜMÜZ", "<span style='color:#55c2bb; font-weight:bold;'>GÜCÜMÜZ</span>");
                                                }
                                            }

                                            <p class="intro_after_featured_word text-sm-left" style="color:floralwhite">
                                                @Html.Raw(subDesc)
                                            </p>

                                            <a href="/Contact/AddContact" class="btn btn-maincolor medium-btn">İletişime Geç</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </li>
            }
        </ul>
    </div>
</section>

<style>
    .intro_featured_word {
        font-size: 36px;
        line-height: 1.5;
    }

    .color-main {
        font-size: inherit;
        font-weight: bold;
        color: #ff6600;
    }

    .slides img,
    .homepage-slider-img {
        width: 100%;
        height: 500px;
        object-fit: cover;
        display: block;
        max-height: 500px;
    }

    .vurgulu {
        color: #55c2bb;
        font-weight: bold;
    }

    @@media screen and (max-width: 768px) {
        .homepage-slider-img

    {
        height: 240px;
        max-height: 240px;
    }

    .intro_featured_word {
        font-size: 22px;
        text-align: center;
    }

    .intro_after_featured_word {
        font-size: 14px;
        text-align: center;
    }

    .intro_layer {
        text-align: center !important;
    }

    .btn.medium-btn {
        font-size: 14px;
        padding: 8px 14px;
        display: inline-block;
    }

    .mouse_down {
        display: none;
    }

    }
</style>
