@model List<Services>

<section id="services" class="ds s-parallax s-overlay section-features s-pt-xl-140 s-pt-lg-120 s-pt-md-80 s-pt-50 s-pb-xl-145 s-pb-lg-125 s-pb-md-85 s-pb-55 c-mb-30 text-center text-sm-left">
    <div class="container">
        <!-- Eski "row" div'ini Owl Carousel div'i ile değiştiriyoruz -->
        <div class="owl-carousel widget widget_partners_carousel"
             id="partners-carousel"
             data-center="false"
             data-margin="20"
             data-loop="true"
             data-autoplay="true"
             data-autoplay-timeout="2000"
             data-responsive-lg="4"
             data-responsive-md="4"
             data-responsive-sm="3"
             data-responsive-xs="2">
            @foreach (var item in Model)
            {
                <!-- Her bir slide için "item" sınıfını ekleyin -->
                <a href="/services/detail/@item.ServicesSlug" class="text-decoration-none">
                    <div class="icon-box text-center">
                        <div class="image-container">
                            @if (item.ServicesImageURL.Contains("icon-spa") ||
                           item.ServicesImageURL.Contains("icon-food") ||
                           item.ServicesImageURL.Contains("icon-herbal") ||
                           item.ServicesImageURL.Contains("icon-headache-1"))
                            {
                                <i class="icon-fonts @item.ServicesImageURL"></i>
                            }
                            else
                            {
                                <img class="yunus1" src="@item.ServicesImageURL" alt="@item.ServicesTitle" loading="lazy"
                                     width="600"
                                     height="400" />
                            }
                        </div>
                        <h6 class="text-uppercase">@item.ServicesTitle</h6>
                        <p>@item.ServicesDescription</p>
                    </div>
                </a>

            }
        </div>
        <div class="mt--30"></div>
    </div>
</section>

<style>
    #services .yunus1 {
        display: block;
        width: 100%;
        max-width: 600px;
        height: 400px;
        object-fit: cover;
        border-radius: 10px;
    }

    /* Mobil görünüm için özel düzenleme */
    @@media (max-width: 576px) {
        #services .image-container

    {
        width: 100%;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 10px;
        margin-bottom: 15px;
    }

    #services .image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 10px;
    }

    }
</style>
