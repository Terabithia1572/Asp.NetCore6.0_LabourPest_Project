@model List<Image>

<section id="gallery" class="ls section-portfolio s-pt-xl-140 s-pt-lg-120 s-pt-md-80 s-pt-50 s-pb-xl-150 s-pb-lg-130 s-pb-md-90 s-pb-60 text-center text-sm-left">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h1 class="special-heading sub-title text-center"><span>GALERİ</span></h1>
                <h2 class="special-heading text-center">Fotoğraf Galerisi</h2>
                <div class="divider-50 hidden-below-md"></div>
                <div class="divider-30 hidden-above-md"></div>
            </div>
        </div>
        <div class="row isotope-wrapper portfolio masonry-layout c-gutter-10 c-mb-10">
            @foreach (var image in Model)
            {
                <div class="@image.ImageClass custom-image-container">
                    <div class="vertical-item item-gallery content-absolute text-center">
                        <div class="item-media">
                            <img src="@image.ImageUpload"
                                 alt="Galeri - @System.IO.Path.GetFileNameWithoutExtension(image.ImageUpload)"
                                 loading="lazy"
                                 class="responsive-gallery-img" />
                        </div>
                        <div class="item-content">
                            <div class="icons-link">
                                <a class="link-zoom photoswipe-link"
                                   aria-label="Resmi büyütmek için tıklayın"
                                   title="Galeriyi büyüt"
                                   href="@image.ImageUpload">
                                    <i class="fa fa-search-plus"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="mb--10"></div>
    </div>
</section>

<style>
    .responsive-gallery-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        aspect-ratio: 3 / 2;
        border-radius: 8px;
        transition: transform 0.3s ease;
    }

        .responsive-gallery-img:hover {
            transform: scale(1.02);
        }

    @@media (max-width: 768px) {
        .responsive-gallery-img

    {
        aspect-ratio: 4 / 3;
    }

    .item-gallery .item-content {
        padding: 0 10px;
    }

    .item-gallery .icons-link i {
        font-size: 18px;
    }

    }
</style>

<link href="~/canabicom/dynamic5/resim.css" rel="stylesheet" />
